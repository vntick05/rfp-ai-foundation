COMPOSE_PROJECT_NAME=rfp-ai-foundation

POSTGRES_DB=proposal_platform
POSTGRES_USER=proposal_user
POSTGRES_PASSWORD=proposal_password
POSTGRES_PORT=15432

ORCHESTRATOR_API_PORT=18010
MODEL_SERVICE_PORT=18011
PORTAINER_PORT=19443

ORCHESTRATOR_LOG_LEVEL=INFO
MODEL_SERVICE_LOG_LEVEL=INFO
MODEL_SERVICE_BASE_IMAGE=python:3.12-slim

DATABASE_URL=postgresql://proposal_user:proposal_password@postgres:5432/proposal_platform

MODEL_SERVICE_BACKEND=mock
MODEL_SERVICE_HOST=0.0.0.0
MODEL_SERVICE_PORT_INTERNAL=8011
MODEL_SERVICE_CONFIG_PATH=/app/configs/model-service.yaml
MODEL_SERVICE_REQUEST_TIMEOUT_SECONDS=60
MODEL_SERVICE_MAX_CONCURRENT_REQUESTS=8
MODEL_SERVICE_OVERLOAD_STATUS_CODE=503
MODEL_SERVICE_REQUEST_ID_HEADER=X-Request-ID
MODEL_SERVICE_MODEL_ID=mock-gpt
MODEL_SERVICE_MODEL_PATH=/models/mock-gpt
MODEL_SERVICE_RUNTIME_MODE=development
MODEL_SERVICE_TENSORRT_LLM_MODE=proxy
MODEL_SERVICE_TENSORRT_LLM_BASE_URL=http://tensorrt-llm:8000
MODEL_SERVICE_TENSORRT_LLM_MODEL_ID=nvidia/Llama-3.3-70B-Instruct-NVFP4
MODEL_SERVICE_TENSORRT_LLM_ENGINE_PATH=/models/tensorrt-llm/llama-3.3-70b-instruct-nvfp4
MODEL_SERVICE_TENSORRT_LLM_CHECKPOINT_PATH=
MODEL_SERVICE_TENSORRT_LLM_HF_CACHE_DIR=/root/.cache/huggingface
MODEL_SERVICE_TENSORRT_LLM_MAX_BATCH_SIZE=1
MODEL_SERVICE_TENSORRT_LLM_MAX_NUM_TOKENS=2048
MODEL_SERVICE_TENSORRT_LLM_MAX_SEQ_LEN=8192
MODEL_SERVICE_TENSORRT_LLM_TOKENIZER_PATH=/models/tensorrt-llm/llama-3.3-70b-instruct-nvfp4
MODEL_SERVICE_TENSORRT_LLM_EMBEDDED_HOST=127.0.0.1
MODEL_SERVICE_TENSORRT_LLM_EMBEDDED_PORT=8020
MODEL_SERVICE_TENSORRT_LLM_EMBEDDED_BACKEND=tensorrt
MODEL_SERVICE_TENSORRT_LLM_SERVER_START_TIMEOUT_SECONDS=180
MODEL_SERVICE_TENSORRT_LLM_EXECUTABLE=trtllm-serve
MODEL_SERVICE_TENSORRT_LLM_REQUEST_TIMEOUT_SECONDS=30

TENSORRT_LLM_IMAGE=nvcr.io/nvidia/tensorrt-llm/release:1.3.0rc3
TENSORRT_LLM_PORT=8000
TENSORRT_LLM_MODEL_ID=nvidia/Llama-3.3-70B-Instruct-NVFP4
TENSORRT_LLM_MODEL_HANDLE=nvidia/Llama-3.3-70B-Instruct-NVFP4
TENSORRT_LLM_MODEL_CACHE_DIR=/models/tensorrt-llm/llama-3.3-70b-instruct-nvfp4
TENSORRT_LLM_EXTRA_LLM_API_OPTIONS=/app/configs/extra-llm-api-options.yml
HF_TOKEN=

NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
